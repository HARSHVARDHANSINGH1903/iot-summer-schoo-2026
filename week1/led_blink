 * Description: LED blink program with serial counter and potentiometer speed control.
 */

int blinkCount = 0;
void setup() {
  pinMode(13, OUTPUT);
  Serial.begin(9600);
}
void loop() {
  int SV = analogRead(A0); 
  digitalWrite(13, HIGH);
  delay(SV);
  digitalWrite(13, LOW);
  delay(SV);
  blinkCount++;
  Serial.print("Blink count: ");
  Serial.println(blinkCount);
}
